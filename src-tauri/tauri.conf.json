{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Silent Voice",
  "version": "0.1.6",
  "identifier": "app.silentvoice.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Silent Voice",
        "width": 980,
        "height": 700,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "visible": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecars/*.dll": "./",
      "sidecars/llama/": "llama/",
      "sidecars/piper/": "piper/",
      "sidecars/sherpa/": "sherpa/"
    },
    "externalBin": ["sidecars/whisper-cpp"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGQzQxMjY3OEUzMEQ1MEMKUldRTTFUQ09aeExFbjIxMGNrS2VKdnpXTGNaMjdyOTN4S3EvT2Jwb0k0UnhQZXRRTFBDaG9kYWMK",
      "endpoints": [
        "https://github.com/zahidhossin39/Silent-Voice/releases/latest/download/latest.json"
      ]
    }
  }
}
